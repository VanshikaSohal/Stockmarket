{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://stockmarket-api.vercel.app"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stockmarket-api.vercel.app/api/:path*"
    }
  ]
}
