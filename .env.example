# ──────────────────────────────────────────────────────────────────────────────
# Portfolio Risk Analyzer — Example Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# Application
PRA_APP_ENV=development
PRA_LOG_LEVEL=INFO
PRA_DEBUG=false

# API Server
PRA_API_HOST=0.0.0.0
PRA_API_PORT=8000
PRA_API_WORKERS=4
PRA_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Paths (relative to project root)
PRA_DATA_DIR=data
PRA_REPORTS_DIR=reports
PRA_MODELS_DIR=models

# Data Collection
PRA_DATA__START_DATE=2020-01-01
PRA_DATA__END_DATE=2024-12-30

# Risk Metrics
PRA_RISK__VAR_CONFIDENCE=0.95
PRA_RISK__CVAR_CONFIDENCE=0.95
PRA_RISK__ROLLING_WINDOW=30
PRA_RISK__ANNUALIZATION_FACTOR=252

# ML Parameters
PRA_ML__TEST_SIZE=0.2
PRA_ML__RANDOM_STATE=42
PRA_ML__SEQUENCE_LENGTH=60
PRA_ML__N_LAGS=5
